{
  "name": "vantisvpn-monorepo",
  "version": "1.1.0",
  "private": true,
  "description": "VantisVPN - Next-Generation Quantum-Resistant Secure VPN System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules",
    "setup": "npm install && turbo run build",
    "ci": "turbo run lint && turbo run test && turbo run build",
    "release": "standard-version && git push --follow-tags"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0",
    "standard-version": "^9.0.0",
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.0.0"
}