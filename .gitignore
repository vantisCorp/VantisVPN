# VantisVPN - Comprehensive .gitignore
# https://github.com/vantisCorp/VantisVPN

# ============== DEPENDENCIES ==============
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp/
.pnp.js

# ============== BUILD OUTPUTS ==============
dist/
build/
.next/
out/
target/
*.wasm
*.dll
*.so
*.dylib
*.a
*.lib
*.exe

# ============== RUST SPECIFIC ==============
**/*.rs.bk
# Cargo.lock should be committed for binary projects
# Cargo.lock
.cargo/config
.cargo/credentials

# ============== PYTHON SPECIFIC ==============
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt
.coverage
.pytest_cache/
htmlcov/
.tox/
.hypothesis/

