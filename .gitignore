.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ============== DEVCONTAINERS ==============
.devcontainer/.devcontainer.json.local
.devcontainer/env.cache

# ============== IDE & EDITORS ==============
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
._*
