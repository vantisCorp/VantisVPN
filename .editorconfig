# EditorConfig for VantisVPN Project
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{rs,rs.in}]
indent_size = 4

[*.{py,py.in}]
indent_size = 4

[*.{sh,bash}]
indent_size = 2

[*.go]
indent_size = 4

[*.{ts,tsx,js,jsx,vue,svelte}]
indent_size = 2

[*.css]
indent_size = 2

[*.scss]
indent_size = 2

[*.html]
indent_size = 2

[*.{sql,graphql,gql}]
indent_size = 2

[*.{dockerfile,Dockerfile*}]
indent_size = 2

[*.tf]
indent_size = 2

[*.{h,cpp,c,hpp,cc,cxx}]
indent_size = 2

[*.java]
indent_size = 4

[*.kt]
indent_size = 4

[*.swift]
indent_size = 4

[*.ex,*.exs]
indent_size = 2

[*.rb]
indent_size = 2

[*.php]
indent_size = 4

[*.lua]
indent_size = 2

[*.{clj,cljs,cljc}]
indent_size = 2

[*.{elm,purs}]
indent_size = 2

[*.{r,R}]
indent_size = 2

[*.{m,mm}]
indent_size = 4

[*.{nim,nims}]
indent_size = 2

[*.{cr,ecr}]
indent_size = 2

[*.{ml,mli,re,rei}]
indent_size = 2

[*.{v,vv}]
indent_size = 4

[*.{lisp,lsp,scm,rkt}]
indent_size = 2

[*.{fs,fsi,fsscript,fsx}]
indent_size = 4

[*.{dart}]
indent_size = 2

[*.{groovy,gvy,gy,gsh}]
indent_size = 4

[*.{pl,pm,t,pod}]
indent_size = 4

[*.{lua}]
indent_size = 2

[*.{zig,zon}]
indent_size = 4

[*.{mojo}]
indent_size = 4